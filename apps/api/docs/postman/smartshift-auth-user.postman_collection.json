{
  "info": {
    "_postman_id": "7fdc71bb-4f3d-4c87-8d86-02ab2f14c001",
    "name": "SmartShift Auth, User & Branch API",
    "description": "Postman collection with sample data for SmartShift Auth, User, and Branch APIs. Import this file, set baseUrl if needed, then run Auth/Register Owner or Auth/Login Owner first to populate accessToken and refreshToken. Branch and User requests use Bearer {{accessToken}}. Run Branches/Create Branch to populate {{branchId}} before branch-dependent requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('ownerEmail')) {",
          "  pm.collectionVariables.set('ownerEmail', `owner.${Date.now()}@smartshift.test`);",
          "}",
          "if (!pm.collectionVariables.get('ownerPassword')) {",
          "  pm.collectionVariables.set('ownerPassword', 'Password123!');",
          "}",
          "if (!pm.collectionVariables.get('newPassword')) {",
          "  pm.collectionVariables.set('newPassword', 'Password456!');",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201 or email already exists', function () {",
                  "  pm.expect([201, 409]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  pm.collectionVariables.set('ownerId', json.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Postman Owner\",\n  \"email\": \"{{ownerEmail}}\",\n  \"password\": \"{{ownerPassword}}\",\n  \"phone\": \"0900000001\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register-owner",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register-owner"
              ]
            }
          }
        },
        {
          "name": "Login Owner",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "  pm.collectionVariables.set('ownerId', json.data.user.id);",
                  "}"
